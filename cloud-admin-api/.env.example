# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/cloud_admin?schema=public

# JWT Secret (generate a strong random string for production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# CAPTCHA (optional - Cloudflare Turnstile or reCAPTCHA)
CAPTCHA_ENABLED=false
CAPTCHA_SECRET=

# CORS
CORS_ORIGIN=*

# Redis (optional - for multi-node rate limiting)
REDIS_URL=
